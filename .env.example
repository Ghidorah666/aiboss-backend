# AIBoss backend environment

PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Alipay Open Platform
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_private_key_without_header_footer
ALIPAY_PUBLIC_KEY=alipay_public_key_for_notify_verify
# Optional explicit name; takes precedence over ALIPAY_PUBLIC_KEY when no key file exists.
ALIPAY_ALIPAY_PUBLIC_KEY=alipay_public_key_for_notify_verify
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify
ALIPAY_RETURN_URL=https://your-domain.com/dashboard.html
ALIPAY_SANDBOX=false
ALIPAY_SKIP_NOTIFY_VERIFY=false

# Database backup
DB_BACKUP_DIR=./data/backups
DB_BACKUP_KEEP=14
