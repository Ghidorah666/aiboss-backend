# AIBoss 后端环境变量配置

# 服务器端口
PORT=3000

# JWT密钥（生产环境请修改为随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 支付宝开放平台配置（申请地址：https://open.alipay.com/）
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_private_key_without_header_footer
ALIPAY_PUBLIC_KEY=alipay_public_key_for_verify
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify

# 沙箱环境（开发测试用，设为true使用沙箱网关）
ALIPAY_SANDBOX=false